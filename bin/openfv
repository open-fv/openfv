#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
# openfv — entry script.
#
# Adds the repo root to sys.path so that `openfv_cli` is importable from a
# plain checkout without any install step.

import os
import sys

# Resolve the repo root (one level above this script's directory).
_script_dir = os.path.dirname(os.path.realpath(__file__))
_repo_root = os.path.dirname(_script_dir)
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

from openfv_cli.main import entry

entry()
